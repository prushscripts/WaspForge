  {
    "id": "INTERACT_OBJECT",
    "displayName": "Interact With Object",
    "category": "interaction",
    "description": "Resolves ObjectsJSON entries and calls TRSObject.WalkInteract with TStringArray actions.",
    "stateEnumName": "INTERACT_OBJECT",
    "inputs": [
      {
        "id": "object_name",
        "label": "Object name (ObjectsJSON)",
        "type": "OBJECT_NAME",
        "required": true,
        "grabHint": "Exact name key in map JSON (e.g. Bank booth)"
      },
      {
        "id": "action",
        "label": "Action uptext",
        "type": "ACTION_TEXT",
        "required": true,
        "grabHint": "Menu option such as Bank, Chop, Mine"
      },
      {
        "id": "json_amount",
        "label": "Unique JSON object count",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "1",
        "grabHint": "ObjectsJSON.GetByName(name, amount) amount parameter"
      },
      {
        "id": "attempts",
        "label": "Hover/attempt count",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "5",
        "grabHint": "WalkInteract attempts parameter"
      }
    ],
    "terminalCondition": "True",
    "doActionTemplate": [
      "procedure TScript.DoInteractObject();",
      "var",
      "  objs: TRSObjectArray;",
      "  idx: Integer;",
      "begin",
      "  Logger.Info('Interacting with object {{object_name}} ({{action}})...');",
      "  objs := TRSObjectArray.Create(Map.Walker, ObjectsJSON.GetByName('{{object_name}}', {{json_amount}}));",
      "  idx := objs.ClosestIndex(Map.Walker.Position());",
      "  objs[idx].WalkInteract(['{{action}}'], {{attempts}});",
      "end;"
    ],
    "getStateCondition": "True"
  },
