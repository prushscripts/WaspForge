  {
    "id": "CLICK_TILE",
    "displayName": "Click Map Tile",
    "category": "interaction",
    "description": "WebWalks into TRSWalker screen-walk range, then uses Map.Walker.Click after Map.Walker.IsWalkable. Optionally sets Map.Walker.TargetUpText/ActionUpText for ChooseOption when an action uptext is required.",
    "stateEnumName": "CLICK_TILE",
    "inputs": [
      {
        "id": "tile",
        "label": "Tile coordinate",
        "type": "COORDINATE",
        "required": true,
        "grabHint": "Global map coordinate to click"
      },
      {
        "id": "action",
        "label": "ChooseOption action (empty for left-click walk)",
        "type": "ACTION_TEXT",
        "required": false,
        "default": "",
        "grabHint": "Leave empty to left-click the tile; otherwise partial uptext for ChooseOption"
      },
      {
        "id": "walk_min_dist",
        "label": "WebWalk min distance (pixels)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "12",
        "grabHint": "Map.Walker.WebWalk minDist before clicking"
      },
      {
        "id": "path_randomness",
        "label": "WebWalk randomness (0.0 - 1.0)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "0.2",
        "grabHint": "Double passed to Map.Walker.WebWalk"
      },
      {
        "id": "click_randomness",
        "label": "Map.Walker.Click pixel jitter",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "8",
        "grabHint": "Integer randomness passed to Map.Walker.Click"
      }
    ],
    "terminalCondition": "True",
    "doActionTemplate": [
      "procedure TScript.DoClickTile();",
      "var",
      "  me, mm: TPoint;",
      "  savedTarget, savedAction, savedWalk: TStringArray;",
      "  wasScreen, hadAction: Boolean;",
      "begin",
      "  me := Map.Walker.Position();",
      "  Logger.Info('Clicking map tile...');",
      "  if not Map.Walker.WebWalk({{tile}}, {{walk_min_dist}}, {{path_randomness}}) then Exit;",
      "  me := Map.Walker.Position();",
      "  if not Map.Walker.IsWalkable({{tile}}, me, mm, Minimap.CompassRadians) then",
      "  begin",
      "    Logger.Warn('Click tile: tile not reachable on mainscreen from current position');",
      "    Exit;",
      "  end;",
      "  savedTarget := Map.Walker.TargetUpText;",
      "  savedAction := Map.Walker.ActionUpText;",
      "  savedWalk := Map.Walker.WalkUpText;",
      "  wasScreen := Map.Walker.ScreenWalk;",
      "  hadAction := Length('{{action}}') > 0;",
      "  Map.Walker.ScreenWalk := True;",
      "  Map.Walker.TargetUpText := [];",
      "  Map.Walker.ActionUpText := [];",
      "  if hadAction then",
      "  begin",
      "    Map.Walker.TargetUpText := ['{{action}}'];",
      "    Map.Walker.ActionUpText := ['{{action}}'];",
      "  end;",
      "  Map.Walker.Walking := True;",
      "  Map.Walker.Click(me, {{tile}}, mm, {{click_randomness}});",
      "  Map.Walker.TargetUpText := savedTarget;",
      "  Map.Walker.ActionUpText := savedAction;",
      "  Map.Walker.WalkUpText := savedWalk;",
      "  Map.Walker.ScreenWalk := wasScreen;",
      "end;"
    ],
    "getStateCondition": "True"
  },
