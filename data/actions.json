[
  {
    "id": "WALK_TO",
    "displayName": "Walk To",
    "category": "movement",
    "description": "Web-walks to a map coordinate using Map.Walker.WebWalk (randomness 0.0–1.0). Completes when Map.Walker.InRange matches.",
    "stateEnumName": "WALK_TO",
    "inputs": [
      {
        "id": "destination",
        "label": "Destination coordinate",
        "type": "COORDINATE",
        "required": true,
        "grabHint": "Stand on the destination tile, then click Grab"
      },
      {
        "id": "min_dist",
        "label": "Minimum distance (pixels, tile scale)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "5",
        "grabHint": "Typical tile pitch is 4 px; catalog templates multiply by 4 for InRange/WebWalk minDist"
      },
      {
        "id": "randomness",
        "label": "Path randomness (0.0 - 1.0)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "0.2",
        "grabHint": "Passed to Map.Walker.WebWalk as Double; must stay within 0.0..1.0"
      }
    ],
    "terminalCondition": "Map.Walker.InRange({{destination}}, {{min_dist}} * 4)",
    "doActionTemplate": [
      "procedure TScript.DoWalkTo();",
      "begin",
      "  Logger.Info('Walking to destination...');",
      "  Map.Walker.WebWalk({{destination}}, {{min_dist}} * 4, {{randomness}});",
      "  SleepUntil(Map.Walker.InRange({{destination}}, {{min_dist}} * 4), 200, 15000);",
      "end;"
    ],
    "getStateCondition": "not Map.Walker.InRange({{destination}}, {{min_dist}} * 4)"
  },
  {
    "id": "USE_FAIRY_RING",
    "displayName": "Use Fairy Ring",
    "category": "movement",
    "description": "Uses FairyRing.Teleport(fairyCode) — WaspLib resolves nearest fairy ring from map JSON when the dial UI is closed.",
    "stateEnumName": "USE_FAIRY_RING",
    "inputs": [
      {
        "id": "fairy_code",
        "label": "Fairy ring code (e.g. dkp, als)",
        "type": "ACTION_TEXT",
        "required": true,
        "grabHint": "Three-letter dial code as shown in-game"
      },
      {
        "id": "approach_tile",
        "label": "Stand near ring (coordinate)",
        "type": "COORDINATE",
        "required": true,
        "grabHint": "Used in GetState so this step only arms when you are beside the fairy ring"
      },
      {
        "id": "approach_slack",
        "label": "Approach slack (pixels)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "96",
        "grabHint": "Radius passed to Map.Walker.InRange for approach_tile"
      },
      {
        "id": "walk_to_ring",
        "label": "Walk to ring if needed",
        "type": "BOOL_VAL",
        "required": false,
        "default": "True",
        "grabHint": "Passes walk flag to FairyRing.Teleport overload"
      }
    ],
    "terminalCondition": "True",
    "doActionTemplate": [
      "procedure TScript.DoUseFairyRing();",
      "begin",
      "  Logger.Info('Teleporting fairy ring {{fairy_code}}...');",
      "  Map.Walker.WebWalk({{approach_tile}}, 32, 0.2);",
      "  SleepUntil(Map.Walker.InRange({{approach_tile}}, {{approach_slack}}), 200, 12000);",
      "  FairyRing.Teleport('{{fairy_code}}', {{walk_to_ring}});",
      "  Minimap.WaitMoving();",
      "end;"
    ],
    "getStateCondition": "Map.Walker.InRange({{approach_tile}}, {{approach_slack}}) and not FairyRing.IsOpen()"
  },
