        "grabHint": "ERSPrayer enum literal, e.g. ERSPrayer.PROTECT_FROM_MELEE"
      }
    ],
    "terminalCondition": "Prayer.IsActive([{{prayer}}])",
    "doActionTemplate": [
      "procedure TScript.DoEnablePrayer();",
      "begin",
      "  Logger.Info('Activating prayer {{prayer}}...');",
      "  if not Prayer.Open() then Exit;",
      "  Prayer.Activate([{{prayer}}]);",
      "end;"
    ],
    "getStateCondition": "not Prayer.IsActive([{{prayer}}])"
  },
  {
    "id": "LOOT_ITEM",
    "displayName": "Loot Ground Item",
    "category": "utility",
    "description": "Samples ERSDot.ITEM minimap dots, projects to mainscreen, right-clicks, and uses ChooseOption.Select for Take (mirrors Antiban.HoverMSTile flow).",
    "stateEnumName": "LOOT_ITEM",
    "inputs": [
      {
        "id": "max_tries",
        "label": "Max minimap samples",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "15",
        "grabHint": "Loop upper bound when searching for visible loot"
      }
    ],
    "terminalCondition": "True",
    "doActionTemplate": [
      "procedure TScript.DoLootItem();",
      "var",
      "  dots: TPointArray;",
      "  tries: Integer;",
      "  a: Double;",
      "  rDot: TPoint;",
      "  msBox: TBox;",
      "  cTPA: TPointArray;",
      "  cArr: TColorArray;",
      "begin",
      "  Logger.Info('Looting ground item...');",
      "  dots := Minimap.GetDots(ERSDot.ITEM);",
      "  if dots = [] then Exit;",
      "  a := Minimap.CompassRadians;",
      "  for tries := 0 to {{max_tries}} - 1 do",
      "  begin",
      "    rDot := dots[Random(Low(dots), High(dots))];",
      "    msBox := Minimap.Vector2MSQuad([rDot.X, rDot.Y, 0], a).Bounds;",
      "    if not MainScreen.Bounds.ContainsBox(msBox) then Continue;",
      "    cArr := Target.GetColors(TPointArray.CreateFromBox(msBox, True));",
      "    cTPA := Target.FindColor(cArr.GetRarest(), 15, msBox);",
      "    if cTPA = [] then Continue;",
      "    Mouse.Move(cTPA.Mean());",
      "    Mouse.Click(EMouseButton.RIGHT);",
      "    if ChooseOption.Select(['Take', 'take']) then Exit;",
      "    ChooseOption.Close();",
      "  end;",
      "end;"
    ],
    "getStateCondition": "Minimap.GetDots(ERSDot.ITEM) <> []"
  },
  {
    "id": "WAIT_XP",
    "displayName": "Wait For XP",
    "category": "utility",
    "description": "Blocks until XP is gained using XPBar.WaitXP(time, interval) per WaspLib defaults.",
    "stateEnumName": "WAIT_XP",
    "inputs": [
      {
        "id": "timeout_ms",
        "label": "Timeout (ms)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "60000",
        "grabHint": "First argument to XPBar.WaitXP"
      },
      {
        "id": "poll_interval",
        "label": "Poll interval (ms, -1 default)",
        "type": "INTEGER_VAL",
        "required": false,
        "default": "-1",
        "grabHint": "Second argument to XPBar.WaitXP; keep -1 for WaspLib default"
      }
    ],
    "terminalCondition": "True",
    "doActionTemplate": [
      "procedure TScript.DoWaitXp();",
      "begin",
      "  Logger.Info('Waiting for XP (timeout {{timeout_ms}} ms)...');",
      "  XPBar.WaitXP({{timeout_ms}}, {{poll_interval}});",
      "end;"
    ],
    "getStateCondition": "True"
  }
]
