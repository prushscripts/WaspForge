(*
  WaspForge — resolve paths under data/ for the checked-out tree.

  Simba 2.0 does not expose ScriptPath. This unit lives in core/, so
  {$MACRO DIR} is always .../WaspForge/core/ and ../data/ is the catalog JSON root.
*)
{$DEFINE WF_PATHS_INCLUDED}
{$IFNDEF WL_OSRS}
  {$I WaspLib/osrs.simba}
{$ENDIF}

function WF_DataPath(const FileName: String): String;
begin
  Result := {$MACRO DIR} + '..' + PATH_SEP + 'data' + PATH_SEP + FileName;
end;

